{
  "manifest_version": 3,
  "name": "AutoApply — Naukri & Workday",
  "version": "1.0.0",
  "description": "Fills your saved profile into Naukri and Workday job applications and submits them for you.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.naukri.com/*",
    "*://*.myworkdayjobs.com/*",
    "*://*.workday.com/*",
    "*://*.myworkday.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.naukri.com/*"],
      "js": ["content-scripts/common-fill-utils.js", "content-scripts/naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.myworkdayjobs.com/*", "*://*.workday.com/*", "*://*.myworkday.com/*"],
      "js": ["content-scripts/common-fill-utils.js", "content-scripts/workday.js"],
      "run_at": "document_idle"
    }
  ]
}
